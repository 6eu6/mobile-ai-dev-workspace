# --- Palmkit Sandbox Server config ---

# Which execution driver to use: "docker" (self-hosted, free) or "e2b" (managed)
SANDBOX_DRIVER=docker

# HTTP port the server listens on
PORT=8787

# Shared secret clients must send as `x-sandbox-token` (generate a long random value)
SANDBOX_API_TOKEN=change-me-to-a-long-random-string

# Kill a sandbox after this many ms of inactivity (keeps a free VM healthy)
SANDBOX_TTL_MS=900000

# Max concurrent sandboxes (protects a small/free host)
SANDBOX_MAX=8

# --- docker driver ---
# Runtime image used to run user projects (built from sandbox.Dockerfile)
SANDBOX_IMAGE=palmkit-sandbox
# Per-container caps
SANDBOX_MEMORY=1g
SANDBOX_CPUS=1.0

# --- e2b driver (only if SANDBOX_DRIVER=e2b) ---
# E2B_API_KEY=e2b_xxx
